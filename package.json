@import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@600;700&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Plus Jakarta Sans", ui-sans-serif, system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
  --font-comfortaa: "Comfortaa", "Plus Jakarta Sans", sans-serif;
}

/* Elegant color theme for Leaflet Map */
.bw-map .leaflet-tile-container {
  transition: all 0.5s ease;
}

.dark-bw-map .leaflet-tile-container {
  transition: all 0.5s ease;
}

.leaflet-container {
  font-family: 'Plus Jakarta Sans', sans-serif !important;
}

/* Beautiful pulse animations for active pothole pins on the visual canvas */
@keyframes circular-pulse {
  0% {
    transform: scale(0.9);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.3);
    opacity: 0.4;
    border-width: 3px;
  }
  100% {
    transform: scale(1.6);
    opacity: 0;
  }
}

.pothole-pulse-critical {
  position: relative;
}
.pothole-pulse-critical::after {
  content: '';
  position: absolute;
  top: -6px;
  left: -6px;
  right: -6px;
  bottom: -6px;
  border: 2px solid #000000;
  border-radius: 50%;
  animation: circular-pulse 1.8s infinite ease-out;
  pointer-events: none;
}

.pothole-pulse-medium {
  position: relative;
}
.pothole-pulse-medium::after {
  content: '';
  position: absolute;
  top: -4px;
  left: -4px;
  right: -4px;
  bottom: -4px;
  border: 1.5px solid #555555;
  border-radius: 50%;
  animation: circular-pulse 2.2s infinite ease-out;
  pointer-events: none;
}

/* Modern styling for Leaflet custom popup and standard Google ecosystem aesthetic */
.leaflet-popup-content-wrapper {
  background: #ffffff !important;
  color: #111111 !important;
  border-radius: 12px !important;
  border: 1px solid #e5e5e5 !important;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
  padding: 2px !important;
}

.leaflet-popup-tip {
  background: #ffffff !important;
  border: 1px solid #e5e5e5 !important;
}

.custom-scrollbar::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

.custom-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background: #e5e5e5;
  border-radius: 10px;
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: #cccccc;
}
